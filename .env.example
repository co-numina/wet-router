# Your wallet private key (base58 encoded)
PRIVATE_KEY=your_base58_private_key_here

# Helius RPC URL (get free key at helius.dev)
RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_API_KEY

# Token mint address
TOKEN_MINT=your_token_mint_address

# Pool address (Meteora DLMM or Raydium)
POOL_ADDRESS=your_pool_address

# Pool type: "meteora" or "raydium"
POOL_TYPE=meteora

# Claim threshold in SOL (claim when fees exceed this amount)
CLAIM_THRESHOLD=0.1

# Poll interval in seconds
POLL_INTERVAL=60

# What percentage of claimed fees to route to LP (0-100)
# Rest stays in wallet as profit
LP_PERCENTAGE=100

# Slippage tolerance for Jupiter swap (in basis points, 100 = 1%)
SLIPPAGE_BPS=100
