# ═══════════════════════════════════════
# wet-router v2 — configuration
# ═══════════════════════════════════════

# Your operator wallet private key (base58)
# This wallet signs distribute + swap + LP txs
# Needs a small SOL balance for tx fees (~0.05 SOL)
PRIVATE_KEY=your_base58_private_key_here

# Helius RPC (get free key at helius.dev)
RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# Jupiter API key (get free at portal.jup.ag)
JUPITER_API_KEY=your_jupiter_api_key

# Token mint address (the pump.fun token)
TOKEN_MINT=your_token_mint_address

# Service wallet — this is the wallet you set as 100% fee recipient
# in pump.fun's fee sharing config
SERVICE_WALLET=your_service_wallet_address

# (Optional) Pool address for LP adding
# If not set, bot will buy tokens and hold them (can add to LP manually)
# POOL_ADDRESS=your_pool_address

# Claim threshold in SOL (route when balance exceeds this)
CLAIM_THRESHOLD=0.05

# Poll interval in seconds
POLL_INTERVAL=120

# % of available SOL to route to LP (rest kept for operating costs)
LP_PERCENTAGE=98

# Jupiter swap slippage (basis points, 200 = 2%)
SLIPPAGE_BPS=200
