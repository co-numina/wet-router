# wet-router configuration
# copy to .env and fill in your values

# === REQUIRED ===
PRIVATE_KEY=           # wallet private key (base58)
RPC_URL=               # helius or other solana RPC endpoint
TOKEN_MINT=            # your token's mint address

# === LP ROUTING ===
# single target, split, or all
# examples:
#   LP_TARGETS=pumpswap
#   LP_TARGETS=pumpswap:60,meteora:40
#   LP_TARGETS=all
LP_TARGETS=pumpswap

# pool addresses (required for each non-pumpswap target)
# METEORA_POOL=
# RAYDIUM_POOL=
# ORCA_POOL=
# PUMPSWAP_POOL=       # optional — auto-derived from TOKEN_MINT

# === TUNING ===
CLAIM_THRESHOLD=0.05   # min SOL to trigger claim+route
POLL_INTERVAL=120      # seconds between checks
SLIPPAGE_BPS=200       # jupiter swap slippage (basis points)
SLIPPAGE_PCT=2         # LP deposit slippage (percent)

# === OPTIONAL ===
# JUPITER_API_KEY=     # from portal.jup.ag (free tier)
